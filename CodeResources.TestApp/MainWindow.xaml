<Window x:Class="CodeResources.TestApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CodeResources.TestApp"
        xmlns:cr="clr-namespace:CodeResource;assembly=CodeResource"
        mc:Ignorable="d"
        Name="root"
        Title="MainWindow" Height="450" Width="800">

    <Window.Resources>
        <cr:StringFormatConverter x:Key="format" />
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        
        <TextBlock Text="Xaml Bindings:" FontSize="18" Grid.ColumnSpan="2" Margin="5" />

        <TextBlock Text="Simple:" Grid.Row="1" Margin="5" />
        <TextBlock Text="{Binding Source={x:Static local:Resource.Instance}, Path=Hello}" Grid.Row="1" Grid.Column="1" Margin="5" />

        <TextBlock Text="Simple additional format:" Grid.Row="2" Margin="5" />
        <TextBlock Text="{Binding Source={x:Static local:Resource.Instance}, Path=Hello, StringFormat={}{0}!!}" Grid.Row="2" Grid.Column="1" Margin="5" />

        <TextBlock Text="Placeholders:" Grid.Row="3" Margin="5" />
        <TextBlock Grid.Row="3" Grid.Column="1" Margin="5">
            <TextBlock.Text>
                <MultiBinding Converter="{x:Static cr:StringFormatConverter.Default}">
                    <Binding Source="{x:Static local:Resource.Instance}" Path="HelloAnd_2S" />
                    <Binding ElementName="root" Path="Name1" />
                    <Binding ElementName="root" Path="Name2" />
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <TextBlock Text="Placeholders additional format:" Grid.Row="4" Margin="5" />
        <TextBlock Grid.Row="4" Grid.Column="1" Margin="5">
            <TextBlock.Text>
                <MultiBinding Converter="{StaticResource format}" StringFormat="{}{0}!!">
                    <Binding Source="{x:Static local:Resource.Instance}" Path="HelloAnd_2S" />
                    <Binding ElementName="root" Path="Name1" />
                    <Binding ElementName="root" Path="Name2" />
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <TextBlock Text="Pluralization:" Grid.Row="5" Margin="5" />
        <TextBlock Grid.Row="5" Grid.Column="1" Margin="5">
            <TextBlock.Text>
                <MultiBinding Converter="{StaticResource format}">
                    <Binding Source="{x:Static local:Resource.Instance}" Path="HelloMyFriend_1S" />
                    <Binding ElementName="root" Path="FriendCount1" />
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <TextBlock Text="Pluralization additional format:" Grid.Row="6" Margin="5" />
        <TextBlock Grid.Row="6" Grid.Column="1" Margin="5">
            <TextBlock.Text>
                <MultiBinding Converter="{StaticResource format}" StringFormat="{}{0}!!">
                    <Binding Source="{x:Static local:Resource.Instance}" Path="HelloMyFriend_1S" />
                    <Binding ElementName="root" Path="FriendCount2" />
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>
    </Grid>
</Window>
